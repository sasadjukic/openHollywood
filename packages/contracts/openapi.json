{
  "components": {
    "schemas": {
      "ArtifactKind": {
        "description": "Stable persisted type names for the initial artifact catalog.",
        "enum": [
          "creative_brief",
          "premise",
          "character",
          "relationship",
          "location",
          "world_rule",
          "beat",
          "scene_plan",
          "critique",
          "continuity_finding",
          "story_blueprint"
        ],
        "title": "ArtifactKind",
        "type": "string"
      },
      "ArtifactReferenceEnvelope": {
        "description": "Immutable artifact-version pointer safe for UI consumption.",
        "properties": {
          "artifact_key": {
            "title": "Artifact Key",
            "type": "string"
          },
          "artifact_kind": {
            "$ref": "#/components/schemas/ArtifactKind"
          },
          "artifact_version_id": {
            "format": "uuid",
            "title": "Artifact Version Id",
            "type": "string"
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          }
        },
        "required": [
          "artifact_kind",
          "artifact_key",
          "artifact_version_id",
          "schema_version"
        ],
        "title": "ArtifactReferenceEnvelope",
        "type": "object"
      },
      "BlueprintDecisionAction": {
        "description": "Human choices accepted at the mandatory Story Blueprint interrupt.",
        "enum": ["approve", "revise", "reject", "fork"],
        "title": "BlueprintDecisionAction",
        "type": "string"
      },
      "BlueprintDecisionRequest": {
        "additionalProperties": false,
        "description": "One idempotent command resolving the active blueprint interrupt.",
        "properties": {
          "action": {
            "$ref": "#/components/schemas/BlueprintDecisionAction"
          },
          "decision_id": {
            "format": "uuid",
            "title": "Decision Id",
            "type": "string"
          },
          "instruction": {
            "anyOf": [
              {
                "maxLength": 10000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Instruction"
          },
          "interrupt_id": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Interrupt Id",
            "type": "string"
          }
        },
        "required": ["decision_id", "interrupt_id", "action"],
        "title": "BlueprintDecisionRequest",
        "type": "object"
      },
      "BlueprintDecisionResponse": {
        "description": "Workflow state after the decision reaches a durable checkpoint.",
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/components/schemas/ArtifactReferenceEnvelope"
            },
            "title": "Artifacts",
            "type": "array"
          },
          "awaiting_approval": {
            "title": "Awaiting Approval",
            "type": "boolean"
          },
          "checkpoint_id": {
            "title": "Checkpoint Id",
            "type": "string"
          },
          "interrupt_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Interrupt Id"
          },
          "workflow_run_id": {
            "format": "uuid",
            "title": "Workflow Run Id",
            "type": "string"
          }
        },
        "required": [
          "workflow_run_id",
          "checkpoint_id",
          "artifacts",
          "awaiting_approval",
          "interrupt_id"
        ],
        "title": "BlueprintDecisionResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ServiceState": {
        "description": "Availability state exposed by the API boundary.",
        "enum": ["ok"],
        "title": "ServiceState",
        "type": "string"
      },
      "ServiceStatus": {
        "description": "Typed response proving the client-to-API contract is available.",
        "properties": {
          "api_version": {
            "title": "Api Version",
            "type": "string"
          },
          "service": {
            "title": "Service",
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/ServiceState"
          }
        },
        "required": ["service", "state", "api_version"],
        "title": "ServiceStatus",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": ["loc", "msg", "type"],
        "title": "ValidationError",
        "type": "object"
      },
      "WorkflowEventEnvelope": {
        "description": "One durable, UI-safe workflow timeline event.",
        "properties": {
          "event_type": {
            "title": "Event Type",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "occurred_at": {
            "format": "date-time",
            "title": "Occurred At",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source"
          },
          "workflow_run_id": {
            "format": "uuid",
            "title": "Workflow Run Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "workflow_run_id",
          "event_type",
          "source",
          "schema_version",
          "payload",
          "occurred_at"
        ],
        "title": "WorkflowEventEnvelope",
        "type": "object"
      },
      "WorkflowEventPage": {
        "description": "Exclusive-cursor replay page for a workflow run.",
        "properties": {
          "events": {
            "items": {
              "$ref": "#/components/schemas/WorkflowEventEnvelope"
            },
            "title": "Events",
            "type": "array"
          },
          "has_more": {
            "title": "Has More",
            "type": "boolean"
          },
          "next_after": {
            "title": "Next After",
            "type": "integer"
          }
        },
        "required": ["events", "next_after", "has_more"],
        "title": "WorkflowEventPage",
        "type": "object"
      }
    }
  },
  "info": {
    "summary": "Local API for the Open Hollywood creative-writing workspace.",
    "title": "Open Hollywood API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "description": "Return stable service metadata without touching external dependencies.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceStatus"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Report API availability",
        "tags": ["system"]
      }
    },
    "/api/v1/workflow-runs/{workflow_run_id}/decisions": {
      "post": {
        "description": "Apply an idempotent approve, revise, reject, or fork command.",
        "operationId": "submitBlueprintDecision",
        "parameters": [
          {
            "in": "path",
            "name": "workflow_run_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Workflow Run Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BlueprintDecisionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlueprintDecisionResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "Workflow run not found"
          },
          "409": {
            "description": "Decision conflicts with durable workflow state"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "503": {
            "description": "Workflow execution service is unavailable"
          }
        },
        "summary": "Resolve the active Story Blueprint human interrupt",
        "tags": ["blueprint-decisions"]
      }
    },
    "/api/v1/workflow-runs/{workflow_run_id}/events": {
      "get": {
        "description": "Return an exclusive-cursor page ordered by global event ID.",
        "operationId": "listWorkflowRunEvents",
        "parameters": [
          {
            "in": "path",
            "name": "workflow_run_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Workflow Run Id",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "after",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "After",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowEventPage"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "Workflow run not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Replay workflow events after a durable cursor",
        "tags": ["workflow-events"]
      }
    },
    "/api/v1/workflow-runs/{workflow_run_id}/events/stream": {
      "get": {
        "description": "Replay missed events, then follow new rows until the client disconnects.",
        "operationId": "streamWorkflowRunEvents",
        "parameters": [
          {
            "in": "path",
            "name": "workflow_run_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Workflow Run Id",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "after",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "After",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "follow",
            "required": false,
            "schema": {
              "default": true,
              "title": "Follow",
              "type": "boolean"
            }
          },
          {
            "in": "header",
            "name": "Last-Event-ID",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Last-Event-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "SSE frames whose data field is a WorkflowEventEnvelope JSON object."
          },
          "404": {
            "description": "Workflow run not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Stream workflow events from a durable cursor",
        "tags": ["workflow-events"]
      }
    }
  }
}
