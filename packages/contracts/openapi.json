{
  "components": {
    "schemas": {
      "ArtifactKind": {
        "description": "Stable persisted type names for the initial artifact catalog.",
        "enum": [
          "creative_brief",
          "premise",
          "character",
          "relationship",
          "location",
          "world_rule",
          "beat",
          "scene_plan",
          "critique",
          "continuity_finding",
          "story_blueprint"
        ],
        "title": "ArtifactKind",
        "type": "string"
      },
      "ArtifactReferenceEnvelope": {
        "description": "Immutable artifact-version pointer safe for UI consumption.",
        "properties": {
          "artifact_key": {
            "title": "Artifact Key",
            "type": "string"
          },
          "artifact_kind": {
            "$ref": "#/components/schemas/ArtifactKind"
          },
          "artifact_version_id": {
            "format": "uuid",
            "title": "Artifact Version Id",
            "type": "string"
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          }
        },
        "required": [
          "artifact_kind",
          "artifact_key",
          "artifact_version_id",
          "schema_version"
        ],
        "title": "ArtifactReferenceEnvelope",
        "type": "object"
      },
      "ArtifactVersionDetail": {
        "description": "Full immutable artifact content and review context.",
        "properties": {
          "artifact": {
            "$ref": "#/components/schemas/WorkspaceArtifact"
          },
          "content": {
            "additionalProperties": true,
            "title": "Content",
            "type": "object"
          },
          "content_sha256": {
            "title": "Content Sha256",
            "type": "string"
          },
          "evaluations": {
            "items": {
              "$ref": "#/components/schemas/WorkspaceEvaluation"
            },
            "title": "Evaluations",
            "type": "array"
          },
          "selected_version": {
            "$ref": "#/components/schemas/ArtifactVersionSummary"
          }
        },
        "required": [
          "artifact",
          "selected_version",
          "content",
          "content_sha256",
          "evaluations"
        ],
        "title": "ArtifactVersionDetail",
        "type": "object"
      },
      "ArtifactVersionSummary": {
        "description": "Version lineage and provider-safe provenance.",
        "properties": {
          "change_summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Change Summary"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "model_identifier": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Identifier"
          },
          "parent_version_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Parent Version Id"
          },
          "provider": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Provider"
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          },
          "specialist_role": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Specialist Role"
          },
          "version_number": {
            "title": "Version Number",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "version_number",
          "parent_version_id",
          "schema_version",
          "change_summary",
          "created_at",
          "specialist_role",
          "provider",
          "model_identifier"
        ],
        "title": "ArtifactVersionSummary",
        "type": "object"
      },
      "BlueprintDecisionAction": {
        "description": "Human choices accepted at the mandatory Story Blueprint interrupt.",
        "enum": ["approve", "revise", "reject", "fork"],
        "title": "BlueprintDecisionAction",
        "type": "string"
      },
      "BlueprintDecisionRequest": {
        "additionalProperties": false,
        "description": "One idempotent command resolving the active blueprint interrupt.",
        "properties": {
          "action": {
            "$ref": "#/components/schemas/BlueprintDecisionAction"
          },
          "decision_id": {
            "format": "uuid",
            "title": "Decision Id",
            "type": "string"
          },
          "instruction": {
            "anyOf": [
              {
                "maxLength": 10000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Instruction"
          },
          "interrupt_id": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Interrupt Id",
            "type": "string"
          }
        },
        "required": ["decision_id", "interrupt_id", "action"],
        "title": "BlueprintDecisionRequest",
        "type": "object"
      },
      "BlueprintDecisionResponse": {
        "description": "Workflow state after the decision reaches a durable checkpoint.",
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/components/schemas/ArtifactReferenceEnvelope"
            },
            "title": "Artifacts",
            "type": "array"
          },
          "awaiting_approval": {
            "title": "Awaiting Approval",
            "type": "boolean"
          },
          "checkpoint_id": {
            "title": "Checkpoint Id",
            "type": "string"
          },
          "interrupt_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Interrupt Id"
          },
          "workflow_run_id": {
            "format": "uuid",
            "title": "Workflow Run Id",
            "type": "string"
          }
        },
        "required": [
          "workflow_run_id",
          "checkpoint_id",
          "artifacts",
          "awaiting_approval",
          "interrupt_id"
        ],
        "title": "BlueprintDecisionResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ProjectList": {
        "description": "All locally persisted projects.",
        "properties": {
          "projects": {
            "items": {
              "$ref": "#/components/schemas/ProjectSummary"
            },
            "title": "Projects",
            "type": "array"
          }
        },
        "required": ["projects"],
        "title": "ProjectList",
        "type": "object"
      },
      "ProjectSummary": {
        "description": "One project in the workspace navigation.",
        "properties": {
          "artifact_count": {
            "title": "Artifact Count",
            "type": "integer"
          },
          "conversation_count": {
            "title": "Conversation Count",
            "type": "integer"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "latest_workflow_run_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latest Workflow Run Id"
          },
          "latest_workflow_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latest Workflow Status"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "story_format": {
            "title": "Story Format",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "story_format",
          "status",
          "updated_at",
          "conversation_count",
          "artifact_count",
          "latest_workflow_run_id",
          "latest_workflow_status"
        ],
        "title": "ProjectSummary",
        "type": "object"
      },
      "ProjectWorkspace": {
        "description": "Persisted project shell consumed by the three-panel client.",
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/components/schemas/WorkspaceArtifact"
            },
            "title": "Artifacts",
            "type": "array"
          },
          "conversations": {
            "items": {
              "$ref": "#/components/schemas/WorkspaceConversation"
            },
            "title": "Conversations",
            "type": "array"
          },
          "project": {
            "$ref": "#/components/schemas/ProjectSummary"
          },
          "workflow_runs": {
            "items": {
              "$ref": "#/components/schemas/WorkspaceRun"
            },
            "title": "Workflow Runs",
            "type": "array"
          }
        },
        "required": ["project", "conversations", "workflow_runs", "artifacts"],
        "title": "ProjectWorkspace",
        "type": "object"
      },
      "ServiceState": {
        "description": "Availability state exposed by the API boundary.",
        "enum": ["ok"],
        "title": "ServiceState",
        "type": "string"
      },
      "ServiceStatus": {
        "description": "Typed response proving the client-to-API contract is available.",
        "properties": {
          "api_version": {
            "title": "Api Version",
            "type": "string"
          },
          "service": {
            "title": "Service",
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/ServiceState"
          }
        },
        "required": ["service", "state", "api_version"],
        "title": "ServiceStatus",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": ["loc", "msg", "type"],
        "title": "ValidationError",
        "type": "object"
      },
      "WorkflowEventEnvelope": {
        "description": "One durable, UI-safe workflow timeline event.",
        "properties": {
          "event_type": {
            "title": "Event Type",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "occurred_at": {
            "format": "date-time",
            "title": "Occurred At",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source"
          },
          "workflow_run_id": {
            "format": "uuid",
            "title": "Workflow Run Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "workflow_run_id",
          "event_type",
          "source",
          "schema_version",
          "payload",
          "occurred_at"
        ],
        "title": "WorkflowEventEnvelope",
        "type": "object"
      },
      "WorkflowEventPage": {
        "description": "Exclusive-cursor replay page for a workflow run.",
        "properties": {
          "events": {
            "items": {
              "$ref": "#/components/schemas/WorkflowEventEnvelope"
            },
            "title": "Events",
            "type": "array"
          },
          "has_more": {
            "title": "Has More",
            "type": "boolean"
          },
          "next_after": {
            "title": "Next After",
            "type": "integer"
          }
        },
        "required": ["events", "next_after", "has_more"],
        "title": "WorkflowEventPage",
        "type": "object"
      },
      "WorkspaceArtifact": {
        "description": "Logical artifact with newest-first immutable versions.",
        "properties": {
          "active_version_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Active Version Id"
          },
          "artifact_key": {
            "title": "Artifact Key",
            "type": "string"
          },
          "artifact_type": {
            "title": "Artifact Type",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "versions": {
            "items": {
              "$ref": "#/components/schemas/ArtifactVersionSummary"
            },
            "title": "Versions",
            "type": "array"
          }
        },
        "required": [
          "id",
          "artifact_key",
          "artifact_type",
          "title",
          "status",
          "active_version_id",
          "versions"
        ],
        "title": "WorkspaceArtifact",
        "type": "object"
      },
      "WorkspaceConversation": {
        "description": "One conversation and its durable messages.",
        "properties": {
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/WorkspaceMessage"
            },
            "title": "Messages",
            "type": "array"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": ["id", "title", "status", "messages"],
        "title": "WorkspaceConversation",
        "type": "object"
      },
      "WorkspaceEvaluation": {
        "description": "Evaluation summary for an artifact version.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "rubric_name": {
            "title": "Rubric Name",
            "type": "string"
          },
          "rubric_version": {
            "title": "Rubric Version",
            "type": "string"
          },
          "scores": {
            "additionalProperties": true,
            "title": "Scores",
            "type": "object"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Summary"
          },
          "weighted_score": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Weighted Score"
          }
        },
        "required": [
          "id",
          "rubric_name",
          "rubric_version",
          "scores",
          "weighted_score",
          "summary",
          "created_at"
        ],
        "title": "WorkspaceEvaluation",
        "type": "object"
      },
      "WorkspaceMessage": {
        "description": "One persisted message in sequence order.",
        "properties": {
          "content": {
            "title": "Content",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "role": {
            "title": "Role",
            "type": "string"
          },
          "sequence_number": {
            "title": "Sequence Number",
            "type": "integer"
          },
          "workflow_run_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Workflow Run Id"
          }
        },
        "required": [
          "id",
          "workflow_run_id",
          "sequence_number",
          "role",
          "content",
          "created_at"
        ],
        "title": "WorkspaceMessage",
        "type": "object"
      },
      "WorkspaceRun": {
        "description": "Workflow status and active human checkpoint.",
        "properties": {
          "active_interrupt_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Active Interrupt Id"
          },
          "completed_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "current_node": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Current Node"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "graph_version": {
            "title": "Graph Version",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "parent_workflow_run_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Parent Workflow Run Id"
          },
          "started_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "workflow_name": {
            "title": "Workflow Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "parent_workflow_run_id",
          "workflow_name",
          "graph_version",
          "status",
          "current_node",
          "active_interrupt_id",
          "started_at",
          "completed_at",
          "updated_at",
          "error_code",
          "error_message"
        ],
        "title": "WorkspaceRun",
        "type": "object"
      }
    }
  },
  "info": {
    "summary": "Local API for the Open Hollywood creative-writing workspace.",
    "title": "Open Hollywood API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/artifact-versions/{artifact_version_id}": {
      "get": {
        "description": "Return one version body, lineage, provider-safe provenance, and scores.",
        "operationId": "getArtifactVersion",
        "parameters": [
          {
            "in": "path",
            "name": "artifact_version_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Artifact Version Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactVersionDetail"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "Artifact version not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Load immutable artifact content and provenance",
        "tags": ["workspace"]
      }
    },
    "/api/v1/health": {
      "get": {
        "description": "Return stable service metadata without touching external dependencies.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceStatus"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Report API availability",
        "tags": ["system"]
      }
    },
    "/api/v1/projects": {
      "get": {
        "description": "Return project navigation data ordered by recent activity.",
        "operationId": "listProjects",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectList"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List locally persisted story projects",
        "tags": ["workspace"]
      }
    },
    "/api/v1/projects/{project_id}/workspace": {
      "get": {
        "description": "Load chat, workflow status, artifacts, and version metadata.",
        "operationId": "getProjectWorkspace",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Project Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectWorkspace"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "Project not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Load one persisted creative workspace",
        "tags": ["workspace"]
      }
    },
    "/api/v1/workflow-runs/{workflow_run_id}/decisions": {
      "post": {
        "description": "Apply an idempotent approve, revise, reject, or fork command.",
        "operationId": "submitBlueprintDecision",
        "parameters": [
          {
            "in": "path",
            "name": "workflow_run_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Workflow Run Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BlueprintDecisionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlueprintDecisionResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "Workflow run not found"
          },
          "409": {
