# Application
OPEN_HOLLYWOOD_ENV=development
OPEN_HOLLYWOOD_DB_PATH=./data/open_hollywood.db
VITE_API_URL=http://127.0.0.1:8000

# Local inference
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional direct Ollama Cloud access. Read only by the runtime secret store.
# Never copy values into model profiles, prompts, artifacts, traces, or exports.
OLLAMA_API_KEY=

# Future optional cloud providers. Copy this file to .env and fill values locally.
OPENAI_API_KEY=
GOOGLE_API_KEY=
