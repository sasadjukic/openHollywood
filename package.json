{
  "name": "open-hollywood",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first agentic creative writing studio",
  "license": "MIT",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.12.0 <12"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "contracts:generate": "uv run --extra api python scripts/export_openapi.py && pnpm --filter @open-hollywood/contracts generate",
    "format": "pnpm --recursive --if-present format",
    "format:check": "pnpm --recursive --if-present format:check",
    "lint": "pnpm --recursive --if-present lint",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "pnpm --recursive --if-present typecheck"
  }
}
